# Copy to .env and edit
MONGO_URI=mongodb://localhost:27017/support
JWT_SECRET=tu_jwt_secreto
PORT=4000
CLIENT_URL=http://localhost:3000
OPENAI_API_KEY=
CHATBOT_AI_ENABLED=false
# Opcional: activa un modelo remoto de Hugging Face si no tienes credito en OpenAI
# HF_API_KEY=hf_...
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct-1M
# HF_MODEL_FALLBACKS=Qwen/Qwen2.5-7B-Instruct,Qwen/Qwen2.5-1.5B-Instruct
# HF_BASE_URL=https://router.huggingface.co/v1/chat/completions

# Fallback local (sin token): modelos publicos de Hugging Face con transformers.js
# LOCAL_HELPER_MODEL=Xenova/flan-t5-small
# LOCAL_TRANSLATE_ES_EN=Xenova/opus-mt-es-en
# LOCAL_TRANSLATE_EN_ES=Xenova/opus-mt-en-es
# LOCAL_CHAT_TEMPERATURE=0.2
# LOCAL_CHAT_MAX_NEW_TOKENS=180
# LOCAL_USE_TRANSLATION=false

# Modo local estricto (usa solo modelos descargados en disco)
# LOCAL_MODELS_ONLY=true
# LOCAL_MODEL_PATH=C:/Users/tu_usuario/Desktop/hf-models
# LOCAL_CACHE_DIR=C:/Users/tu_usuario/Desktop/hf-cache
# Si ya descargaste los repos en LOCAL_MODEL_PATH, puedes usar solo el nombre de carpeta:
# LOCAL_HELPER_MODEL=flan-t5-small

